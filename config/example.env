# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED CREDENTIALS
# -----------------------------------------------------------------------------

# Anthropic API key for Claude
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Google Sheets export (optional -- policies are always saved to data/policies.json)
# To enable: create a Google Cloud service account with Sheets API access,
# share your spreadsheet with the service account email, then use ONE of:
#
# Option A: Point to the JSON key file (easiest)
# GOOGLE_CREDENTIALS_FILE=path/to/service-account.json
#
# Option B: Paste the JSON key directly
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}
#
# Option C: Paste base64-encoded JSON (legacy)
# GOOGLE_CREDENTIALS=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
#
# Google Spreadsheet ID (from the URL)
# From URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
# SPREADSHEET_ID=your-spreadsheet-id-here

# -----------------------------------------------------------------------------
# OPTIONAL OVERRIDES
# -----------------------------------------------------------------------------

# Override any setting from settings.yaml using:
# POLICYSEARCH__SECTION__KEY=value

# Example: Use Haiku model instead of Sonnet (cheaper)
# POLICYSEARCH__ANALYSIS__ANALYSIS_MODEL=claude-haiku-4-5-20251001

# Example: Increase rate limit delay
# POLICYSEARCH__CRAWL__DELAY_SECONDS=5.0

# Example: Disable LLM analysis (keyword matching only)
# POLICYSEARCH__ANALYSIS__ENABLE_LLM_ANALYSIS=false

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------

# Set to 'development' to enable additional logging
# ENVIRONMENT=development

# Dry run mode - don't write to Google Sheets
# DRY_RUN=true
