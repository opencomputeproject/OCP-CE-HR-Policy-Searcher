# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED CREDENTIALS
# -----------------------------------------------------------------------------

# Anthropic API key for Claude
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Google service account credentials (base64 encoded)
# 1. Create service account in Google Cloud Console
# 2. Download JSON key file
# 3. Encode: base64 -i credentials.json | tr -d '\n'
# 4. Paste result here
GOOGLE_CREDENTIALS=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Google Spreadsheet ID
# From URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
SPREADSHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# -----------------------------------------------------------------------------
# OPTIONAL OVERRIDES
# -----------------------------------------------------------------------------

# Override any setting from settings.yaml using:
# POLICYSEARCH__SECTION__KEY=value

# Example: Use Haiku model instead of Sonnet (cheaper)
# POLICYSEARCH__ANALYSIS__LLM_MODEL=claude-haiku-4-20250514

# Example: Increase rate limit delay
# POLICYSEARCH__CRAWL__DELAY_SECONDS=5.0

# Example: Disable LLM analysis (keyword matching only)
# POLICYSEARCH__ANALYSIS__ENABLE_LLM_ANALYSIS=false

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------

# Set to 'development' to enable additional logging
# ENVIRONMENT=development

# Dry run mode - don't write to Google Sheets
# DRY_RUN=true
