# =============================================================================
# SITE CREDENTIALS (EXAMPLE)
# =============================================================================
# Copy this file to credentials.yaml and fill in your credentials.
# NEVER commit credentials.yaml to version control!
# The .gitignore already excludes this file.
# =============================================================================

credentials:
  # ----- Form-based login (Playwright) -----
  # Fills username/password fields and clicks submit.
  # Cookies persist in the Playwright browser context for the session.
  - domain: "example.com"
    auth_type: "form"
    login_url: "https://example.com/login"
    username: "your_username"
    password: "your_password"
    username_field: "#username"              # CSS selector for username input
    password_field: "#password"              # CSS selector for password input
    submit_button: "button[type=submit]"     # CSS selector for submit button

  # ----- HTTP Basic Auth -----
  # Sends Authorization header on every request to this domain.
  - domain: "internal.example.com"
    auth_type: "basic"
    username: "user"
    password: "pass"

  # ----- Cookie injection -----
  # Sets cookies on the browser context / HTTP client before crawling.
  # Useful for session tokens obtained out-of-band.
  - domain: "portal.example.com"
    auth_type: "cookie"
    cookies:
      - name: "session_id"
        value: "abc123"
      - name: "auth_token"
        value: "xyz789"

  # ----- Custom header(s) -----
  # Adds custom HTTP headers on every request to this domain.
  # Useful for API keys, bearer tokens, etc.
  - domain: "api.legiscan.com"
    auth_type: "header"
    headers:
      X-API-Key: "your_api_key_here"
